DATABASE_URL="postgresql://deploy_talent:deploy_talent@localhost:5432/deploy_talent?schema=public"
ENV_MODE="DEV"
JWT_SECRET="change-me"
JWT_EXPIRES_IN="15m"
PORT=3000

# LocalStack (docker compose: localstack em 127.0.0.1:4566; bucket criado em setup-localstack.sh)
AWS_REGION="us-east-1"
S3_BUCKET="files"
S3_ENDPOINT="http://127.0.0.1:4566"
S3_FORCE_PATH_STYLE="true"
S3_ACCESS_KEY_ID="test"
S3_SECRET_ACCESS_KEY="test"

# SES via LocalStack (identidade: awslocal ses verify-email-identity; LOCALSTACK_SES_FROM no script)
EMAIL_FROM="noreply@localhost"
EMAIL_ENDPOINT="http://127.0.0.1:4566"
EMAIL_ACCESS_KEY_ID="test"
EMAIL_SECRET_ACCESS_KEY="test"

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recruiters  User[]
  jobs        Job[]
  apps        Application[]
  evaluations Evaluation[]
  history     ApplicationHistory[]

  @@map("tenants")
}


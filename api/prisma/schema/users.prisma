model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  tenantId     String?
  /** Chave S3: `tenants/{tenantId}/users/{userId}/avatar/{uuid}.{ext}` (recrutadores / admins B2B). */
  avatarKey    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  sourcedApplications      Application[]              @relation("SourcedBy")
  movedApplications        ApplicationHistory[]       @relation("MovedBy")
  candidateProfile         Candidate?
  invitationsCreated       Invitation[]               @relation("InvitationsCreated")
  completedStageProgresses ApplicationStageProgress[] @relation("StageProgressCompletedBy")

  @@index([tenantId])
  @@map("users")
}


model Application {
  id                 String            @id @default(uuid())
  tenantId           String
  jobId              String
  candidateId        String
  status             ApplicationStatus @default(APPLIED)
  currentJobStageId  String?
  sourcedByUserId    String?
  appliedAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant       Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job          Job                        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate    Candidate                  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  sourcedBy    User?                      @relation("SourcedBy", fields: [sourcedByUserId], references: [id], onDelete: SetNull)
  currentStage JobStage?                  @relation("CurrentJobStage", fields: [currentJobStageId], references: [id], onDelete: SetNull)
  history      ApplicationHistory[]
  evaluations  Evaluation[]
  progresses   ApplicationStageProgress[]

  @@unique([tenantId, jobId, candidateId])
  @@index([tenantId])
  @@index([jobId])
  @@index([candidateId])
  @@index([sourcedByUserId])
  @@index([currentJobStageId])
  @@map("applications")
}

model ApplicationHistory {
  id            String            @id @default(uuid())
  tenantId      String
  applicationId String
  movedByUserId String?
  fromStatus    ApplicationStatus
  toStatus      ApplicationStatus
  fromStage     String?
  toStage       String?
  createdAt     DateTime          @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  movedBy     User?       @relation("MovedBy", fields: [movedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([applicationId])
  @@index([movedByUserId])
  @@map("application_history")
}


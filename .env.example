# O `DATABASE_URL` da API tem de bater com POSTGRES_USER, POSTGRES_PASSWORD e POSTGRES_DB
# (host `postgres`, porta 5432, rede do Compose).

# Postgres
POSTGRES_DB=deploy_talent
POSTGRES_USER=deploy_talent
POSTGRES_PASSWORD=deploy_talent

# MinIO (API e healthcheck usam as mesmas credenciais)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_HOST=minio
MINIO_PORT=9000

# API
ENV_MODE=DEV
PORT=3050
DATABASE_URL=postgresql://deploy_talent:deploy_talent@postgres:5432/deploy_talent?schema=public
JWT_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=10m
JWT_REFRESH_EXPIRES_IN=24h
AWS_REGION=us-east-1
S3_BUCKET=files
S3_ENDPOINT=http://minio:9000
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
EMAIL_FROM=noreply@localhost
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
CORS_ORIGINS=http://localhost:3000
WEB_BASE_URL=http://localhost:3000

# Build da Web no Compose
NEXT_PUBLIC_API_BASE_URL=http://localhost:3050
# Opcional: true para faixa de demonstração na Web.
IS_DEMO=
